!This namelist contains various input parameters for RAMSES runs

&RUN_PARAMS
hydro=.true.
poisson=.true.
nrestart=0
ncontrol=10
nremap=5
nsubcycle=2*1,35*2
verbose=.false.
/

&AMR_PARAMS
levelmin=5
levelmax=14
ngridtot=400000
nexpand=30*2
boxlen=0.191405298315250E-01 ! to be changed is alpha_dense_core changes in order to always have in code units the cloud radius r0=boxlen/4
/

&BOUNDARY_PARAMS
/

&INIT_PARAMS
condinit_kind ='collapse'
alpha_dense_core=0.1
beta_dense_core=0.01d0
crit_dense_core=0.08
delta_rho=0.1d0
/

&OUTPUT_PARAMS
noutput=1
!foutput=25
tout=9.2e-05
/

&POISSON_PARAMS
gravity_type=0
epsilon=1d-4
cg_levelmin=30 !put switch when MG starts to fail to converge
/

&HYDRO_PARAMS
gamma=1.666667
courant_factor=0.6
slope_type=1
scheme='muscl'
riemann='llf'
riemann2d='llf'
pressure_fix=.true.
/


&UNITS_PARAMS
units_density=0.383460000000000E-23
units_time=0.197732040946880E+16
units_length=3.0857d18
/

&COOLING_PARAMS
barotropic_eos=.true.
barotropic_eos_form='2nd_collapse'
polytrope_rho=3.866301516d-15,3.866301516d-10,3.866301516d-5
polytrope_index=0.4,-0.3,0.56667
T_eos=10d0
mu_gas=2.31d0
/

&REFINE_PARAMS
jeans_refine=30*8.
interpol_var=0
interpol_type=1
/
